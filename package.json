{
  "name": "chat-app",
  "version": "1.0.0",
  "description": "Premium Chat Application",
  "main": "server/index.js",
  "scripts": {
    "start": "node server/index.js",
    "dev": "nodemon server/index.js",
    "css": "tailwindcss -i ./src/input.css -o ./public/css/tailwind.css --minify",
    "css:watch": "tailwindcss -i ./src/input.css -o ./public/css/tailwind.css --watch",
    "build": "npm run css"
  },
  "dependencies": {
    "express": "^4.18.2",
    "socket.io": "^4.7.2",
    "bcryptjs": "^2.4.3",
    "uuid": "^9.0.0",
    "multer": "^1.4.5-lts.1"
  },
  "devDependencies": {
    "nodemon": "^3.0.1",
    "tailwindcss": "^3.4.14",
    "postcss": "^8.4.47",
    "autoprefixer": "^10.4.20"
  }
}
